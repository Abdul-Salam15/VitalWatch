DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vitalwatch?schema=public"

# Auth.js
AUTH_SECRET="change-me-to-a-random-secret"

# Resend (email) — set RESEND_API_KEY to enable real sending
RESEND_API_KEY=""
EMAIL_FROM="VitalWatch <onboarding@resend.dev>"

# App URL used in email links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: protects /api/cron/check-reminders (Authorization: Bearer <secret>)
CRON_SECRET=""
