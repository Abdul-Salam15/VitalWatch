DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vitalwatch?schema=public"

# Auth.js
AUTH_SECRET="change-me-to-a-random-secret"

# Brevo (email) — set BREVO_API_KEY to enable real sending
# Create an API key at https://app.brevo.com/settings/keys/api
BREVO_API_KEY=""
EMAIL_FROM_NAME="VitalWatch"
EMAIL_FROM_ADDRESS="onboarding@vitalwatch.app"

# App URL used in email links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: protects /api/cron/check-reminders (Authorization: Bearer <secret>)
CRON_SECRET=""
